{
  "$ref": "#/definitions/articles",
  "definitions": {
    "articles": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "deck": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "Distribution",
            "Direct",
            "AI",
            "AI · Luxury",
            "Channels",
            "Operations",
            "Commercial",
            "Strategy"
          ]
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "readTime": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "seo": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "image": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "related": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "collection": {
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "collection"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "slug": {
                    "type": "string"
                  },
                  "collection": {
                    "type": "string"
                  }
                },
                "required": [
                  "slug",
                  "collection"
                ],
                "additionalProperties": false
              }
            ]
          }
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "deck",
        "category",
        "date",
        "readTime"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}