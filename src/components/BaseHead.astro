---
import { getSite, type Lang } from '../lib/cms';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  author?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  lang,
  image,
  type = 'website',
  publishedTime,
  author,
  noindex = false,
} = Astro.props;

const site = await getSite(lang);
const resolvedAuthor = author ?? site.principal.fullName;

// Resolve image: page-specific if provided, otherwise the default OG image from site settings
const resolvedImage = image && image.trim() !== '' ? image : site.defaultOgImage;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = resolvedImage ? new URL(resolvedImage, Astro.site).toString() : '';

const localeMap = { en: 'en_US', it: 'it_IT', es: 'es_ES' } as const;

// Build hreflang alternates by swapping locale prefix on the current path
const pathname = Astro.url.pathname;
function pathFor(target: Lang): string {
  const stripped = pathname.replace(/^\/(it|es)(\/|$)/, '/');
  if (target === 'en') return stripped;
  return stripped === '/' ? `/${target}/` : `/${target}${stripped}`;
}
const alternates = {
  en: new URL(pathFor('en'), Astro.site).toString(),
  it: new URL(pathFor('it'), Astro.site).toString(),
  es: new URL(pathFor('es'), Astro.site).toString(),
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={resolvedAuthor} />

<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="en" href={alternates.en} />
<link rel="alternate" hreflang="it" href={alternates.it} />
<link rel="alternate" hreflang="es" href={alternates.es} />
<link rel="alternate" hreflang="x-default" href={alternates.en} />

{noindex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImageURL && (
  <>
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
  </>
)}
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content={localeMap[lang]} />
{lang !== 'en' && <meta property="og:locale:alternate" content="en_US" />}
{lang !== 'it' && <meta property="og:locale:alternate" content="it_IT" />}
{lang !== 'es' && <meta property="og:locale:alternate" content="es_ES" />}

{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{type === 'article' && <meta property="article:author" content={resolvedAuthor} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

<link rel="icon" type="image/svg+xml" href={site.favicon} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-friendly summary" />
<link rel="alternate" type="application/rss+xml" title={`${site.name} · Writing`} href="/rss.xml" />
