---
// Footer.astro — renders footer from navigation.{lang}.json
import { getNavigation, type Lang } from '../lib/cms';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const nav = await getNavigation(lang);

const year = new Date().getFullYear();
const copyright = nav.footer.copyright.replace('{year}', String(year));
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <svg class="footer-mark" viewBox="0 0 120 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="10" y="10" width="20" height="80" rx="10" fill="#FFFFFF"></rect>
          <rect x="50" y="35" width="20" height="55" rx="10" fill="#FFFFFF"></rect>
          <polygon points="50,18 70,18 60,33" fill="#DC1F26"></polygon>
          <rect x="90" y="20" width="20" height="70" rx="10" fill="#FFFFFF"></rect>
        </svg>
        <div class="footer-brand-name">{nav.brand}</div>
        <p class="footer-brand-tag">{nav.footer.tagline}</p>
      </div>

      {nav.footer.columns.map(col => (
        <div class="footer-col">
          <h4>{col.heading}</h4>
          <ul>
            {col.links.map(link => (
              <li>
                {link.href ? (
                  <a href={link.href} {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                    {link.label}
                  </a>
                ) : (
                  <span>{link.label}</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer-bottom">
      <span>{copyright}</span>
      <span>{nav.footer.bottom}</span>
    </div>
  </div>
</footer>
