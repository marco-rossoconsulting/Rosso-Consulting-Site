---
// Footer.astro — renders footer from navigation.{lang}.json
import { getNavigation, type Lang } from '../lib/cms';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const nav = await getNavigation(lang);

const year = new Date().getFullYear();
const copyright = nav.footer.copyright.replace('{year}', String(year));
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/logo.jpg" alt="" class="footer-mark" width="120" height="48" aria-hidden="true" />
        <div class="footer-brand-name">{nav.brand}</div>
        <p class="footer-brand-tag">{nav.footer.tagline}</p>
      </div>

      {nav.footer.columns.map(col => (
        <div class="footer-col">
          <h4>{col.heading}</h4>
          <ul>
            {col.links.map(link => (
              <li>
                {link.href ? (
                  <a href={link.href} {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                    {link.label}
                  </a>
                ) : (
                  <span>{link.label}</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer-bottom">
      <span>{copyright}</span>
      <span>{nav.footer.bottom}</span>
    </div>
  </div>
</footer>
