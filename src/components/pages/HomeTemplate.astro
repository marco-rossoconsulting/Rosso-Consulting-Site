---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../Hero.astro';
import SectionHeader from '../SectionHeader.astro';
import Lane from '../Lane.astro';
import CTABlock from '../CTABlock.astro';
import { getHomePage, getAdvisoryEntries, getUi, type Lang } from '../../lib/cms';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const page = await getHomePage(lang);
const advisoryEntries = await getAdvisoryEntries({ featuredOnly: true });
const ui = await getUi(lang);
---

<BaseLayout
  title={page.seo.title}
  description={page.seo.description}
  image={page.seo.ogImage}
  lang={lang}
  currentPage="home"
>
  <Hero
    eyebrowNum={page.hero.eyebrowNum}
    eyebrowLabel={page.hero.eyebrowLabel}
    headline={page.hero.headline}
    sub={page.hero.sub}
    meta={page.hero.meta}
  />

  <!-- Practice lanes -->
  <section>
    <div class="container">
      <SectionHeader num={page.practice.num} title={page.practice.title} />
      <p class="section-intro reveal">{page.practice.intro}</p>
      <div class="lanes" style="margin-top: var(--s-5);">
        {page.practice.lanes.map((lane, i) => (
          <Lane
            num={lane.num}
            title={lane.title}
            body={lane.body}
            formats={lane.formats}
            isFirst={i === 0}
            isLast={i === page.practice.lanes.length - 1}
          />
        ))}
      </div>
      <div class="reveal" style="margin-top: var(--s-6); text-align: center;">
        <a href={page.practice.ctaHref} class="link-arrow">{page.practice.ctaLabel} →</a>
      </div>
    </div>
  </section>

  <!-- Audiences -->
  <section style="background: var(--nebbia); padding-top: 0; padding-bottom: 0;">
    <div class="container" style="padding-left: 0; padding-right: 0; max-width: var(--container);">
      <div class="section-header reveal" style="padding: clamp(64px, 10vh, 144px) var(--gutter) var(--s-8);">
        <span class="section-number">{page.audiences.num}</span>
        <span class="section-rule"></span>
        <h2>{page.audiences.title}</h2>
      </div>
      <div class="audience-bar reveal">
        {page.audiences.items.map((item, i) => (
          <div class="audience-item">
            <span class="audience-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{item.heading}</h3>
            <p>{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Active engagements (dynamic from advisory collection + overrides) -->
  <section>
    <div class="container">
      <SectionHeader num={page.active.num} title={page.active.title} />
      <p class="section-intro reveal">{page.active.intro}</p>
      <div class="grid-2 reveal" style="margin-top: var(--s-6); gap: var(--s-4) var(--s-5);">
        {advisoryEntries.map(entry => (
          <div class="card-premium">
            <div class="card-label">{entry.data.role} · {entry.data.stage}</div>
            <h3>{entry.data.name}</h3>
            <p>{entry.data.description}</p>
          </div>
        ))}
      </div>
      <div class="reveal" style="margin-top: var(--s-6); text-align: center;">
        <a href={page.active.ctaHref} class="link-arrow">{page.active.ctaLabel} →</a>
      </div>
    </div>
  </section>

  <!-- Operating now -->
  <section class="section-dark">
    <div class="container">
      <SectionHeader num={page.operatingNow.num} title={page.operatingNow.title} dark />
      <div class="editorial-split reveal" style="margin-top: var(--s-6);">
        <div class="split-accent">
          <div class="section-hero-label">{page.operatingNow.roleLabel}</div>
          <h3 class="section-hero-title" set:html={page.operatingNow.roleTitle} />
          <p class="section-body">{page.operatingNow.company}</p>
        </div>
        <div>
          <div class="section-hero-label">{page.operatingNow.whyMattersLabel}</div>
          <p class="section-body">{page.operatingNow.whyMattersBody}</p>
        </div>
      </div>
    </div>
  </section>

  <CTABlock
    label={page.cta.label}
    headline={page.cta.headline}
    sub={page.cta.sub}
    accent={page.cta.accent}
    buttonLabel={page.cta.buttonLabel}
    buttonHref={page.cta.buttonHref}
  />
</BaseLayout>
