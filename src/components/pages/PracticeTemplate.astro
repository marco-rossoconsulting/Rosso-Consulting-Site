---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../Hero.astro';
import SectionHeader from '../SectionHeader.astro';
import PullQuote from '../PullQuote.astro';
import CTABlock from '../CTABlock.astro';
import { getPracticePage, type Lang } from '../../lib/cms';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const page = await getPracticePage(lang);
---

<BaseLayout
  title={page.seo.title}
  description={page.seo.description}
  image={page.seo.ogImage}
  lang={lang}
  currentPage="practice"
>
  <Hero
    eyebrowNum={page.hero.eyebrowNum}
    eyebrowLabel={page.hero.eyebrowLabel}
    headline={page.hero.headline}
    sub={page.hero.sub}
  />

  <!-- Methodology -->
  <section>
    <div class="container">
      <SectionHeader num={page.methodology.num} title={page.methodology.title} />
      <p class="section-intro reveal">{page.methodology.intro}</p>
      <div class="principles-grid reveal" style="margin-top: var(--s-6);">
        {page.methodology.principles.map(pr => (
          <div class="principle-card">
            <span class="principle-num">{pr.n}</span>
            <h3>{pr.h}</h3>
            <p>{pr.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Formats -->
  <section style="background: var(--nebbia);">
    <div class="container">
      <SectionHeader num={page.formats.num} title={page.formats.title} />
      <p class="section-intro reveal">{page.formats.intro}</p>
      <div class="formats-grid reveal" style="margin-top: var(--s-6);">
        {page.formats.items.map(f => (
          <div class="format-card">
            <span class="format-letter">{f.n}</span>
            <h3>{f.h}</h3>
            <p>{f.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PullQuote quote={page.pullquote} />

  <!-- Tech approach -->
  <section>
    <div class="container">
      <SectionHeader num={page.techApproach.num} title={page.techApproach.title} />
      <p class="section-intro reveal">{page.techApproach.intro}</p>
      <div class="grid-3 reveal" style="margin-top: var(--s-6); gap: var(--s-5);">
        {page.techApproach.blocks.map(block => (
          <div class="tech-block">
            <div class="label" style="color: var(--rosso); margin-bottom: var(--s-2);">{block.label}</div>
            <h3 style="font-family: var(--font-display); font-size: 20px; text-transform: uppercase; letter-spacing: 0.005em; margin-bottom: var(--s-2);">{block.h}</h3>
            <p style="color: var(--grigio); font-size: 14px; line-height: 1.6;">{block.p}</p>
          </div>
        ))}
      </div>
      <div class="reveal vendor-independence">
        <div class="label" style="color: var(--rosso); margin-bottom: var(--s-2);">{page.techApproach.vendorIndependence.label}</div>
        <p style="color: var(--carbone); font-size: 15px; line-height: 1.6; max-width: 75ch;">{page.techApproach.vendorIndependence.body}</p>
      </div>
    </div>
  </section>

  <!-- Lifecycle -->
  <section class="section-dark">
    <div class="container">
      <SectionHeader num={page.lifecycle.num} title={page.lifecycle.title} dark />
      <p class="section-intro reveal" style="color: var(--grigio-soft);">{page.lifecycle.intro}</p>
      <div class="lifecycle-stack reveal" style="margin-top: var(--s-6);">
        {page.lifecycle.phases.map((ph, i) => (
          <div class="phase-card" style={i === page.lifecycle.phases.length - 1 ? 'margin-bottom: 0;' : ''}>
            <span class="phase-label">{ph.y}</span>
            <h3>{ph.h}</h3>
            <p>{ph.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABlock
    label={page.cta.label}
    headline={page.cta.headline}
    sub={page.cta.sub}
    accent={page.cta.accent}
    buttonLabel={page.cta.buttonLabel}
    buttonHref={page.cta.buttonHref}
  />
</BaseLayout>
